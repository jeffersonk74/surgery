generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  chirurgien
  assistant
}

enum PatientStatut {
  en_attente
  pret
  en_cours
  termine
  archive
}

enum AssistantStatut {
  en_attente
  pret
}

enum OperationStatut {
  en_cours
  succes
  echec
  annule
}

enum HistoriqueStatut {
  terminee
  annulee
  echec
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nom       String
  prenom    String
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patientsAsChirurgien Patient[]  @relation("ChirurgienPatients")
  patientsAsAssistant Patient[]  @relation("AssistantPatients")
  operations           Operation[]
  assistantStatuses    AssistantStatus[]

  @@map("users")
}

model Patient {
  id          Int           @id @default(autoincrement())
  patientId   String        @unique @map("patient_id")
  nom         String
  prenom      String
  pathologie  String
  statut      PatientStatut @default(en_attente)
  consentementPatient Boolean @default(false) @map("consentement_patient")
  consentementAt DateTime?   @map("consentement_at")

  chirurgienId Int?         @map("chirurgien_id")
  chirurgien   User?         @relation("ChirurgienPatients", fields: [chirurgienId], references: [id])
  
  assistantId  Int?         @map("assistant_id")
  assistant    User?         @relation("AssistantPatients", fields: [assistantId], references: [id])
  
  operations        Operation[]
  assistantStatuses AssistantStatus[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("patients")
}

model AssistantStatus {
  id        Int             @id @default(autoincrement())
  statut    AssistantStatut @default(en_attente)
  updatedAt DateTime        @updatedAt @map("updated_at")

  patientId   Int @map("patient_id")
  patient     Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  assistantId Int @map("assistant_id")
  assistant   User @relation(fields: [assistantId], references: [id], onDelete: Cascade)

  @@unique([patientId, assistantId])
  @@map("assistant_status")
}

model Operation {
  id             Int               @id @default(autoincrement())
  dateDebut      DateTime?         @map("date_debut")
  dateFin        DateTime?         @map("date_fin")
  dureeSeconds   Int?              @map("duree_seconds")
  statut         OperationStatut   @default(en_cours)
  blockchainHash String?           @map("blockchain_hash")
  createdAt      DateTime          @default(now()) @map("created_at")

  patientId    Int @map("patient_id")
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  chirurgienId Int @map("chirurgien_id")
  chirurgien   User @relation(fields: [chirurgienId], references: [id])

  blockchainLogs BlockchainLog[]

  @@map("operations")
}

model BlockchainLog {
  id        Int      @id @default(autoincrement())
  sessionId String   @map("session_id")
  hash      String
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  operationId Int?       @map("operation_id")
  operation   Operation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  @@map("blockchain_logs")
}

model HistoriqueOperation {
  id          Int                  @id @default(autoincrement())
  patientId   String               @map("patient_id")
  nom         String
  prenom      String
  pathologie  String
  dateDebut   DateTime?            @map("date_debut")
  dateFin     DateTime?            @default(now()) @map("date_fin")
  statut      HistoriqueStatut
  createdAt   DateTime             @default(now()) @map("created_at")

  @@map("historique_operations")
}

model RobotState {
  id             Int       @id @default(autoincrement())
  isConnected    Boolean   @default(false) @map("is_connected")
  lastPing       DateTime? @map("last_ping")
  port           String?
  simulationMode Boolean   @default(false) @map("simulation_mode")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("robot_state")
}

model SystemSession {
  id              Int       @id @default(autoincrement())
  sessionId       String    @unique @map("session_id")
  assistantOnline Boolean   @default(false) @map("assistant_online")
  assistantReady  Boolean   @default(false) @map("assistant_ready")
  robotConnected  Boolean   @default(false) @map("robot_connected")
  activePatientId String?   @map("active_patient_id")
  lastUpdated     DateTime  @updatedAt @map("last_updated")

  @@map("system_sessions")
}
