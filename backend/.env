# Database URL for Prisma
# SQLite pour développement (pas besoin de serveur PostgreSQL)
DATABASE_URL="file:./dev.db"



# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Arduino Configuration (Mode Local - utilisé si ROBOT_MODE=local)
ARDUINO_PORT=/dev/ttyACM0
ARDUINO_BAUDRATE=115200

# Robot Mode: "local" (SerialPort direct) ou "android_bridge" (WebSocket via Android)
# Pour l'architecture 2 PCs (WiFi), PC2 utilise "local" (MEGA en USB)
ROBOT_MODE=local

# Configuration 2 PCs WiFi (optionnel - pour documentation)
# PC1 (Joystick) envoie à PC2 (Robot) via WiFi Socket.io
# PC2_IP doit être configuré dans pc1/joystick_sender.py